# Copy this file to ".env" (with the dot at the start, no .example) and fill
# in ONE of the API keys below. The .env file is YOURS and stays on your
# computer — it never gets shared on GitHub.

# Pick whichever you already have an account with. The AI is used to read the
# free-text daily reports your reporters send in and turn them into entries,
# and to write the editor's accountability brief.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional overrides — leave commented out unless you know what you're doing.
# NEWSROOM=               # label the dashboard, e.g. NEWSROOM="MakanDay"
# AI_PROVIDER=anthropic   # or "openai" — auto-detected from the key above
# MODEL=                  # e.g. "claude-sonnet-4-6" or "gpt-5.4" to override default
# OPENAI_BASE_URL=        # advanced: route OpenAI calls through OpenRouter, Groq, Ollama
# PORT=3000

# Email intake (reporters self-report by email). OFF unless INBOUND_EMAIL_SECRET
# is set. Point your mail service (SendGrid Inbound Parse / Mailgun Routes /
# Postmark / a Cloudflare Email-Routing Worker) at "POST /inbound/email" and have
# it present this secret (header x-grounded-inbound-secret, ?k=, or a "secret"
# field). INBOUND_EMAIL_DOMAIN is just for displaying the address the dashboard
# shows reporters (reports+<token>@<that-domain>).
# INBOUND_EMAIL_SECRET=
# INBOUND_EMAIL_DOMAIN=   # e.g. in.grounded.developai.co.za

# Usage sharing with Develop AI is ON by default. On startup the app sends ONLY:
# a random install id, your newsroom name (if set above), the app version, your
# OS, and activity counts (how many reporters / entries / briefs / errors). It
# NEVER sends reporter names, story titles, URLs, or report text — your data
# stays on your computer. This just lets us see the Node is being used.
# To turn it OFF completely, uncomment the line below:
# GROUNDED_TELEMETRY=off
